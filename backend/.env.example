# Порт, на якому слухає backend (Railway задає автоматично через PORT)
PORT=3001

# Токен Telegram-бота - потрібен для верифікації initData з Mini App
BOT_TOKEN=123456:ABC-your-bot-token-here

# Дозволені origin для CORS (домен твого frontend на Vercel)
# можна вказати кілька, розділених комою
FRONTEND_ORIGIN=http://localhost:5173,https://bananaview.vercel.app

# Час неактивності кімнати (мс), після якого вона видаляється з пам'яті
ROOM_TTL_MS=21600000
